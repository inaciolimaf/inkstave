# Frontend environment template (Vite). Copy to `.env` or `.env.local`.
# Only VITE_-prefixed vars are exposed to the client bundle.

# Backend origin/base used by the typed API client.
VITE_API_BASE_URL=http://localhost:8000

# Polling interval (ms) for the compile-status fallback used when the SSE
# event stream is unavailable. Default 1000.
VITE_COMPILE_POLL_INTERVAL_MS=1000

# Base URL for the spec-29 collaboration WebSocket (`ws://…/ws/collab`).
# Defaults to the API origin with the http→ws scheme; set to "" to disable
# live collaboration and fall back to single-user REST autosave.
VITE_COLLAB_WS_URL=ws://localhost:8000/ws/collab

# Frontend notification-bell poll interval (ms).
VITE_NOTIFICATIONS_POLL_INTERVAL_MS=60000

# Show the AI agent chat panel (spec 46; "false" hides it).
VITE_AGENT_ENABLED=true
