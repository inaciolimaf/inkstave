# Inkstave environment template.
#
# Copy this file to `.env` and adjust values for your machine:
#
#     cp .env.example .env
#
# `.env` is git-ignored and must never be committed. This template documents
# every variable used so far; later specs append new rows (and never remove
# these). All defaults here are safe, non-secret, dev-only values.

# --- PostgreSQL ---
POSTGRES_USER=inkstave          # Postgres role
POSTGRES_PASSWORD=inkstave      # Postgres password (dev only — change in prod)
POSTGRES_DB=inkstave            # Postgres database name
POSTGRES_PORT=5432              # host port mapped to the Postgres container

# --- Redis ---
REDIS_PORT=6379                 # host port mapped to the Redis container

# --- Connection strings ---
# Full async DSN used by SQLAlchemy / asyncpg (read by spec 02; used by spec 03).
DATABASE_URL=postgresql+asyncpg://inkstave:inkstave@localhost:5432/inkstave
# Redis connection URL (cache / pub-sub / ARQ broker).
REDIS_URL=redis://localhost:6379/0
# Database used by the test suite (spec 04). Provisioned/dropped by the harness.
TEST_DATABASE_URL=postgresql+asyncpg://inkstave:inkstave@localhost:5432/inkstave_test

# --- Backend application (spec 02) ---
ENVIRONMENT=dev                          # dev | test | prod
DEBUG=false                              # verbose errors + SQLAlchemy SQL echo (spec 03)
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
LOG_JSON=true                            # JSON logs (true) vs. console (false)
DOCS_ENABLED=true                        # expose /docs and /redoc
REQUEST_ID_HEADER=X-Request-ID           # request correlation header name
# CORS_ORIGINS is defined once in the Security hardening section below.
# --- Observability (spec 51) ---
LOG_FORMAT=json                          # json | console (pretty, dev only)
LOG_STACKS=true                          # include tracebacks in error logs (false in prod)
SERVICE_NAME=inkstave-backend            # `service` log field / build_info
APP_VERSION=0.0.0                        # inkstave_build_info version
GIT_SHA=unknown                          # inkstave_build_info git_sha (set in CI)
METRICS_PUBLIC=true                      # gate /metrics exposure (bind to internal net in prod)
OTEL_ENABLED=false                       # turn OpenTelemetry tracing on
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317  # OTLP target when enabled
OTEL_SERVICE_NAME=inkstave-backend       # OTel resource attribute
READINESS_CHECK_TIMEOUT_S=2              # per-dependency /readyz probe timeout (seconds)

# --- Performance & test speed (spec 53) ---
DB_POOL_SIZE=10                          # SQLAlchemy async pool size
DB_MAX_OVERFLOW=5                        # extra connections beyond the pool
DB_POOL_TIMEOUT=30                       # seconds to wait for a pooled connection
CACHE_ENABLED=true                       # hot-read Redis cache master switch
CACHE_TTL_SECONDS=30                     # hot-read cache TTL
SUITE_BUDGET_SECONDS=120                 # hard CI gate: fail if the suite exceeds this
SUITE_WARN_SECONDS=90                    # early-warning threshold
SLOW_TEST_WARN_S=3                       # per-test warn threshold
SLOW_TEST_FAIL_S=10                      # per-test fail threshold (non-@slow)
TEST_DB_TEMPLATE=inkstave_test_tmpl      # template DB name (xdist clone source)

# --- Security hardening (spec 52) ---
CORS_ORIGINS=http://localhost:5173       # CORS allow-list; spec name CORS_ALLOWED_ORIGINS also accepted
HSTS_ENABLED=false                       # emit Strict-Transport-Security (true in prod)
# CSP_POLICY=                            # override the default Content-Security-Policy
TRUST_PROXY_HEADERS=false                # trust X-Forwarded-For for client IP (only behind a proxy)
MAX_REQUEST_BODY_BYTES=1048576           # global JSON body cap (1 MiB)
# MAX_UPLOAD_BYTES is defined once in the Storage section below.
# UPLOAD_ALLOWED_EXTENSIONS=             # override the upload extension allow-list (comma list)
RATE_LIMIT_COMPILE=20/60                 # per-user compile cap (limit/window_seconds)
RATE_LIMIT_AGENT=30/60                   # per-user agent cap
RATE_LIMIT_UPLOAD=60/60                  # per-user upload cap

# --- Password hashing (argon2id, spec 06) ---
ARGON2_TIME_COST=3                       # iterations
ARGON2_MEMORY_COST=65536                 # KiB of memory
ARGON2_PARALLELISM=4                     # lanes

# --- JWT authentication (spec 07) ---
# REQUIRED: HS256 signing secret. Use >=32 random bytes, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-dev-only-secret-change-me-0123456789
# Retired secrets accepted for verification only (comma/JSON list) during rotation.
JWT_SECRET_PREVIOUS=
JWT_ALGORITHM=HS256                      # RS256 is a documented future option
JWT_ISSUER=inkstave                      # iss claim
ACCESS_TOKEN_TTL_SECONDS=900             # access token lifetime (15 min)
REFRESH_TOKEN_TTL_SECONDS=1209600        # refresh token lifetime / Redis TTL (14 days)

# --- Frontend (spec 09; Vite reads VITE_-prefixed vars — see frontend/.env.example) ---
# VITE_API_BASE_URL=http://localhost:8000   # backend origin for the SPA's API client
# CORS_ORIGINS above already allows the Vite dev origin (http://localhost:5173).

# --- Auth guards & rate limiting (spec 08) ---
RATE_LIMIT_ENABLED=true                  # master switch for the limiter
RATE_LIMIT_AUTH_LOGIN=10/300             # <limit>/<window_seconds> per IP+email (legacy: RATE_LIMIT_LOGIN)
RATE_LIMIT_REGISTER=5/3600               # per IP
RATE_LIMIT_REFRESH=30/300                # per IP
RATE_LIMIT_AUTH_PASSWORD=5/3600          # change-password / sensitive auth (user_or_ip)
RATE_LIMIT_VERIFY_EMAIL=5/3600           # per email+IP cap on verification (re)send (spec 104)
RATE_LIMIT_MAGIC_LINK=5/3600             # per email+IP cap on magic-link requests (spec 104)
RATE_LIMIT_RESET_PASSWORD=10/3600        # per-IP cap on reset-password callbacks (spec 104)
TRUSTED_PROXY_HEADER=X-Forwarded-For     # source of the real client IP
WS_AUTH_CLOSE_CODE=4401                  # WS unauthorized close code (contract, spec 29)

# --- Documents (spec 13) ---
MAX_DOCUMENT_BYTES=2000000               # max UTF-8 bytes of a single document

# --- LaTeX compilation / Tectonic (spec 21) ---
TECTONIC_BIN=tectonic                      # path/name of the Tectonic executable
TECTONIC_CACHE_DIR=/var/cache/tectonic     # persistent package cache (mount a volume)
TECTONIC_BUNDLE_URL=                       # optional pinned bundle; empty = default
TECTONIC_OFFLINE=false                     # true = only cached/bundled packages
COMPILE_WORKDIR_ROOT=/tmp/inkstave-compiles  # root for per-compile workdirs
TECTONIC_COMPILE_TIMEOUT_S=60              # wall-clock timeout per compile
COMPILE_MAX_INPUT_FILES=2000               # assembly file-count cap
COMPILE_MAX_INPUT_BYTES=104857600          # assembly total-size cap (100 MiB)
TREE_MAX_NODES=50000                       # safety cap on tree nodes materialised per read
COMPILE_MAX_OUTPUT_BYTES=104857600         # output total-size cap (100 MiB)
COMPILE_MAX_LOG_BYTES=2097152              # captured .log truncation cap (2 MiB)
COMPILE_MAX_STDOUT_BYTES=262144            # stdout/stderr capture cap (256 KiB)
COMPILE_CPU_SECONDS=60                      # best-effort RLIMIT_CPU (empty disables)
COMPILE_ADDRESS_SPACE_BYTES=2147483648     # best-effort RLIMIT_AS (empty disables)
COMPILE_KEEP_WORKDIR_ON_FAILURE=false      # keep failed workdirs for debugging

# --- Compile output storage & retention (spec 23) ---
COMPILE_OUTPUT_PREFIX=compiles             # storage key prefix for compile outputs
COMPILE_RETAIN_PER_PROJECT=10              # keep the newest N compiles' outputs per project
COMPILE_RETENTION_MAX_AGE_S=2592000        # expire outputs older than this (30 days)
COMPILE_RETENTION_SWEEP_S=3600             # cleanup-job interval (sub-hourly → runs every N min)
COMPILE_RETENTION_BATCH=200                # max compiles processed per sweep
COMPILE_PDF_CACHE_MAX_AGE_S=60             # Cache-Control max-age for the PDF response

# --- Async compile API / ARQ jobs (spec 22) ---
COMPILE_MAX_CONCURRENT_PER_PROJECT=1       # max queued+running compiles per project
COMPILE_MAX_CONCURRENT_PER_USER=3          # max queued+running compiles per user
COMPILE_DEBOUNCE_COALESCE=true             # non-force request returns the in-flight compile
COMPILE_JOB_TIMEOUT_S=120                  # ARQ job timeout (must exceed engine timeout)
COMPILE_QUEUE_NAME=compiles                # ARQ queue / Redis key prefix
COMPILE_SSE_KEEPALIVE_S=15                 # SSE keep-alive comment interval
COMPILE_CANCEL_FLAG_TTL_S=300              # TTL for the Redis cancel flag

# --- SyncTeX source <-> PDF sync (spec 26) ---
SYNCTEX_MAX_GZ_BYTES=33554432             # refuse to parse synctex.gz larger than this (32 MiB)
SYNCTEX_INDEX_CACHE_SIZE=16               # parsed synctex indices cached per process (0 disables)

# --- LaTeX log -> problems parsing (spec 27) ---
LOGPARSE_MAX_LOG_BYTES=8388608            # tail-truncate logs larger than this before parsing (8 MiB)
LOGPARSE_WRAP_WIDTH=79                     # TeX log hard-wrap width used for de-wrapping
LOGPARSE_MAX_PROBLEMS=1000                # cap on the number of problems returned

# --- Server-side CRDT document model (spec 28) ---
COLLAB_SNAPSHOT_EVERY_UPDATES=200         # compact the CRDT log after this many updates
COLLAB_SNAPSHOT_INTERVAL_SECONDS=30       # or after this many seconds since the last snapshot
COLLAB_TEXT_FLUSH_DEBOUNCE_MS=1000        # debounce for flushing CRDT text into spec-13 content
COLLAB_IDLE_EVICT_SECONDS=300             # drop idle in-memory CRDT docs after this long
COLLAB_MAX_UPDATE_BYTES=1048576           # reject a single CRDT update larger than this (1 MiB)

# --- Collaboration WebSocket transport (spec 29) ---
COLLAB_WS_MAX_FRAME_BYTES=1048576         # max inbound WebSocket frame size
COLLAB_WS_SEND_QUEUE_MAX=256              # bounded per-connection send buffer
COLLAB_WS_SLOW_CLIENT_TIMEOUT_MS=2000     # slow-consumer enqueue timeout
COLLAB_WS_MAX_MSGS_PER_SEC=200            # inbound message rate guard per connection
COLLAB_WS_PING_INTERVAL_SECONDS=25        # idle ping interval (delegated to the ASGI server)
COLLAB_WS_PONG_TIMEOUT_SECONDS=10         # pong timeout before close (delegated to the ASGI server)
COLLAB_REDIS_CHANNEL_PREFIX=collab:doc:   # Redis pub/sub channel prefix (one per document)

# --- Collaborators & sharing (spec 33) ---
FRONTEND_URL=http://localhost:5173        # base for invite accept links (/invite/{token})
INVITE_TTL_DAYS=14                        # pending invite lifetime
EMAIL_CHANGE_TOKEN_TTL=86400              # email-change confirmation token lifetime (spec 59)

# --- Access control (spec 34) ---
COMPILE_ALLOWED_FOR_VIEWERS=true          # viewers may trigger/read compiles

# --- Version-history capture (spec 36) ---
HISTORY_CAPTURE_ENABLED=true              # observe the CRDT stream into version history
HISTORY_DEBOUNCE_MS=5000                  # idle debounce before flushing buffered updates
HISTORY_FLUSH_MAX_BUFFER=200              # raw updates buffered before a forced flush
HISTORY_CHUNK_MAX_UPDATES=100             # captured updates per chunk before sealing + new snapshot
HISTORY_INLINE_MAX_BYTES=65536            # payloads/snapshots above this offload to blob storage
HISTORY_COMPACT_MIN_UPDATES=50            # min updates before the sweep compacts a doc
HISTORY_COMPACT_MERGE_BYTES=4096          # adjacent updates smaller than this may be merged
HISTORY_COMPACT_INTERVAL_S=300            # compaction sweep interval (mocked in tests)
HISTORY_BLOB_PREFIX=history/              # blob-storage key prefix for offloaded history

# --- History API (spec 37) ---
HISTORY_DIFF_MAX_BYTES=2097152            # max reconstructed text per diff side before 413
HISTORY_VERSIONS_PAGE_MAX=200             # upper bound for the versions list `limit` (set false for editor+)

# --- AI writing agent (spec 41) ---
OPENROUTER_API_KEY=                       # required only when the real LLM client is built
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1  # OpenAI-SDK base URL (swap provider here)
AGENT_MODEL=openai/gpt-4o-mini            # model id passed to the SDK
AGENT_TEMPERATURE=0.2                     # default sampling temperature
AGENT_MAX_ITERATIONS=8                    # hard cap on plan loops per turn
AGENT_MAX_TOTAL_TOKENS=60000             # hard cap on accumulated tokens per turn
AGENT_MAX_TOKENS_PER_CALL=1024            # max_tokens per LLM call
AGENT_REQUEST_TIMEOUT_S=60                # per-call timeout for the real client
AGENT_HTTP_REFERER=https://inkstave.local # OpenRouter HTTP-Referer header
AGENT_APP_TITLE=Inkstave                  # OpenRouter X-Title header
AGENT_TOOL_READ_MAX_CHARS=40000           # char cap for read_file output (spec 42)
AGENT_TOOL_SEARCH_MAX_RESULTS=50          # upper bound for search_project.max_results
AGENT_TOOL_TREE_MAX_NODES=500             # node cap for list_tree
AGENT_TOOL_EDIT_MAX_CHARS=200000          # char cap for propose_edit.new_text
AGENT_DIFF_CONTEXT_LINES=3                 # unified-diff context lines per hunk (spec 43)
AGENT_DIFF_MAX_DOC_CHARS=400000           # refuse to diff documents larger than this
AGENT_STREAM_TRANSPORT=sse                 # sse | ws (spec 44)
AGENT_STREAM_HEARTBEAT_S=15                # SSE heartbeat interval
AGENT_RUN_TTL_S=900                        # TTL for per-run last-event + cancel keys
AGENT_MAX_MESSAGE_CHARS=8000              # max user message length
AGENT_CONTEXT_TOKEN_BUDGET=8000           # select_context token budget (spec 48)
AGENT_CONTEXT_SURROUNDING_LINES=40        # context lines around a located section
AGENT_SECTION_EXTRA_COMMANDS=             # extra sectioning command names (comma-separated)
AGENT_CONTEXT_CACHE=memory                # memory | redis | off
# --- Agent safety: rate limits, budgets, audit (spec 49); 0 disables a cap ---
AGENT_MAX_RUNS_PER_MINUTE_PER_USER=10
AGENT_MAX_CONCURRENT_RUNS_PER_USER=2
AGENT_MAX_RUNS_PER_MINUTE_PER_PROJECT=20
AGENT_MAX_TOKENS_PER_RUN=120000
AGENT_MAX_COST_PER_RUN_USD=0.30          # keep ≤ the per-day-per-user cap below
AGENT_MAX_TOKENS_PER_DAY_PER_PROJECT=2000000
AGENT_MAX_COST_PER_DAY_PER_USER_USD=0.30  # ~R$0.50/day per user
AGENT_MODEL_COST_TABLE={"openai/gpt-4o-mini":{"input":0.00015,"output":0.0006}}
AGENT_AUDIT_RETENTION_DAYS=90             # 0 = keep forever
AGENT_INJECTION_GUARD=on                  # on | off

# --- Email + notifications (spec 39 / 103) ---
# Three concrete recipes (flip EMAIL_BACKEND + the SMTP/Resend keys):
#   1. Dev / Mailpit (capture locally, see http://localhost:8025):
#        EMAIL_BACKEND=smtp  SMTP_HOST=mailpit (or host.docker.internal)  SMTP_PORT=1025
#        SMTP_USER=  SMTP_PASSWORD=  SMTP_USE_TLS=false
#   2. Production via Resend over SMTP (zero new code):
#        EMAIL_BACKEND=smtp  SMTP_HOST=smtp.resend.com  SMTP_PORT=587 (or 465)
#        SMTP_USER=resend  SMTP_PASSWORD=<RESEND_API_KEY>  SMTP_USE_TLS=true
#   3. Production via the native Resend HTTP API:
#        EMAIL_BACKEND=resend  RESEND_API_KEY=re_...
EMAIL_BACKEND=console                     # smtp | console | file | resend  (console in dev/tests)
EMAIL_FROM=Inkstave <no-reply@inkstave.local>  # default From header
EMAIL_FILE_DIR=./tmp/emails               # output dir for the FileEmailSender
SMTP_HOST=localhost                       # SMTP host (dev/Mailpit: mailpit; Resend: smtp.resend.com)
SMTP_PORT=587                             # SMTP port (Mailpit: 1025; Resend: 587 or 465)
SMTP_USER=                                # SMTP username (Mailpit: empty; Resend: resend)
SMTP_PASSWORD=                            # SMTP password (Resend: your RESEND_API_KEY)
SMTP_USE_TLS=true                         # STARTTLS/TLS (Mailpit: false; Resend: true)
# Native Resend HTTP API sender (only used when EMAIL_BACKEND=resend). Free tier
# ~3k emails/month at https://resend.com. NEVER commit a real key (.env is git-ignored).
RESEND_API_KEY=                           # Resend API key (re_...) — required iff EMAIL_BACKEND=resend
APP_BASE_URL=http://localhost             # base for accept_url / reset_url / verify_url in emails
PASSWORD_RESET_TOKEN_TTL=3600             # password-reset link lifetime (seconds)
EMAIL_VERIFICATION_TOKEN_TTL=86400        # account email-verification link lifetime
# Email link-based auth flows (spec 104).
MAGIC_LOGIN_TOKEN_TTL=600                 # passwordless sign-in link lifetime (seconds)
REQUIRE_VERIFIED_EMAIL_TO_LOGIN=false     # if true, credential login requires a confirmed email
NOTIFICATION_INVITE_TTL_DAYS=30           # TTL for invite notifications
NOTIFICATION_SWEEP_INTERVAL_S=3600        # expiry sweep interval (mocked in tests)
VITE_NOTIFICATIONS_POLL_INTERVAL_MS=60000 # frontend bell poll interval
VITE_AGENT_ENABLED=true                   # show the AI agent chat panel (spec 46; "false" hides it)

# --- Binary file storage (spec 14) ---
FILE_STORAGE_BACKEND=local               # local | s3
FILE_STORAGE_LOCAL_PATH=./data/files     # base dir for the local backend
MAX_UPLOAD_BYTES=52428800                # per-file upload limit (50 MiB)
ALLOWED_UPLOAD_MIME=image/png,image/jpeg,image/gif,image/webp,image/svg+xml,application/pdf,text/plain,application/x-bibtex,text/x-bibtex
STORAGE_STREAM_CHUNK_BYTES=65536         # streaming chunk size
# Project import from a .zip archive (spec 101). Bounds are enforced from the
# central directory BEFORE any decompression (zip-bomb defence); the upload is
# size-guarded while streaming. Defaults are safe and keep tests cheap.
IMPORT_MAX_ZIP_BYTES=52428800            # max compressed upload size (50 MiB)
IMPORT_MAX_UNCOMPRESSED_BYTES=314572800  # max total uncompressed across kept entries (300 MiB)
IMPORT_MAX_FILE_BYTES=52428800           # max uncompressed size of any single entry (50 MiB)
IMPORT_MAX_ENTRIES=2000                  # max kept (folders+docs+files) entries
IMPORT_ALLOWED_EXTENSIONS=.tex,.bib,.cls,.sty,.bst,.bbx,.cbx,.txt,.md,.csv,.tsv,.json,.yml,.yaml,.xml,.svg,.png,.jpg,.jpeg,.gif,.webp,.pdf,.eps
IMPORT_WORKDIR_ROOT=/tmp/inkstave-imports  # scratch dir for the bounded temp zip copy
# --- Project export (spec 102) ---
# The whole project streams out as a .zip (no full-archive buffering). The stream
# chunk size reuses STORAGE_STREAM_CHUNK_BYTES (no separate knob).
EXPORT_MAX_TOTAL_BYTES=209715200          # max total (doc + file) bytes for the sync path; over → 413
EXPORT_ASYNC_ENABLED=false                # true: over-threshold projects build via an ARQ artifact (optional)
# S3 backend (only when FILE_STORAGE_BACKEND=s3; S3_BUCKET then required):
S3_ENDPOINT_URL=                         # custom endpoint for MinIO/S3-compatible
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- E2E / test profile (spec 54) ---
# Deterministic stubs that keep the Playwright suite fast (backend settings):
COMPILE_MODE=real                        # real | mock — "mock" emits a canned PDF/log (no Tectonic); e2e uses mock
LLM_STUB=false                           # true swaps the agent LLM for a deterministic in-process stub (no network); e2e uses true
# Playwright-side knobs (read by frontend/playwright.config.ts; all optional):
E2E_BASE_URL=http://localhost:4173       # where Playwright points the browser (Vite preview origin)
E2E_API_URL=http://localhost:8099        # backend origin the e2e frontend talks to
E2E_DATABASE_URL=postgresql+asyncpg://inkstave:inkstave@localhost:5433/inkstave_e2e  # docker-compose.test.yml Postgres
E2E_REDIS_URL=redis://localhost:6380/0   # docker-compose.test.yml Redis
E2E_PLAYWRIGHT_WORKERS=                  # parallel workers (blank = from cores)
E2E_RETRIES=                             # flake retries (blank = 1 in CI, 0 local)
# Note: the LLM stub is wired via dependency injection (LLM_STUB=true), so there is
# no separate stub HTTP server / LLM_STUB_URL to configure.

# --- Production packaging (spec 56; docker-compose.prod.yml) ---
# Host port the nginx reverse proxy publishes (put real TLS in front of it).
PUBLIC_HTTP_PORT=80
# The prod compose derives DATABASE_URL/REDIS_URL from the POSTGRES_* vars above
# and the internal service hostnames (postgres/redis), and sets FILE_STORAGE_LOCAL_PATH
# (/data/files volume) + TECTONIC_CACHE_DIR (/var/cache/tectonic volume) itself — you
# do NOT set those for prod. The shared backend image selects API vs worker by the
# compose `command` (no INKSTAVE_PROCESS selector needed).
# PROD REQUIREMENTS: set ENVIRONMENT=prod ⇒ a strong JWT_SECRET (>=32 bytes), a
# non-empty CORS_ORIGINS (your public origin) and DATABASE_URL are enforced at boot.

# --- CI/CD & first-run bootstrap (spec 57) ---
# `ENVIRONMENT` (above) is the env switch (dev | test | prod) — there is no separate
# INKSTAVE_ENV. Run `python -m inkstave.cli check-config` to validate before deploy.
MIGRATE_ON_START=false                    # strict: refuse to start unless the DB is at head.
#                                          # The prod `migrate` step runs `inkstave migrate`
#                                          # (advisory-locked); set true only for single-node/dev.
# First-admin bootstrap (read by `inkstave bootstrap-admin`; unset after first run):
# INKSTAVE_ADMIN_EMAIL=admin@example.com
# INKSTAVE_ADMIN_PASSWORD=                # use a strong, unique value; never commit it
# Demo seed is opt-in via the CLI flag (`inkstave seed --demo`); never runs in prod
# without `--force`. There is no auto-seed env var.
