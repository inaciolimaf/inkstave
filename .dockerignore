# Build context = repo root for both images (the backend needs infra/tectonic,
# the frontend needs infra/nginx). Keep the context lean and never leak secrets.

# Secrets — must never enter an image layer.
.env
.env.*
!.env.example

# VCS / tooling / CI
.git
.gitignore
.github
.pre-commit-config.yaml
.editorconfig
.claude

# Docs, specs, ADRs, reference repos — not needed at runtime.
docs
specs
*.md
!backend/README.md

# Python caches / virtualenvs / tests
**/__pycache__
**/*.pyc
**/.venv
**/.mypy_cache
**/.ruff_cache
**/.pytest_cache
backend/tests
backend/htmlcov
**/.coverage
coverage.xml

# Node / frontend build artefacts and tests
**/node_modules
frontend/dist
# e2e specs/reports aren't needed at runtime, BUT `pnpm build` runs `tsc -b`,
# which type-checks playwright.config.ts → it imports e2e/support/env.ts. Keep
# the support dir in context or the frontend image build fails (TS2307); the
# files never reach the final image (multi-stage: runtime = nginx + dist only).
frontend/e2e/*
!frontend/e2e/support
frontend/playwright-report
frontend/test-results
frontend/coverage

# Local data / scratch
data
**/.DS_Store
docker-compose*.yml
